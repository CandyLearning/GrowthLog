{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "paths": { "@/*": ["./src/*"] },
    "outDir": "./dist-test",
    "useDefineForClassFields": false
  },
  "include": ["steps/**/*.ts", "support/**/*.ts", "page-objects/**/*.ts"]
}
