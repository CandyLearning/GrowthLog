// GrowthLog — Entity Relationship Model
// 產出 Phase：02 Entity Modeling
// 產出日期：2026-05-08

// ─────────────────────────────────────────
// 共用 Audit 欄位（每張 table 均包含）
// ─────────────────────────────────────────
// created_by  integer    [ref: > users.id]  建立者 user id
// created_at  timestamp                     建立時間
// updated_by  integer    [ref: > users.id]  最後修改者 user id
// updated_at  timestamp                     最後修改時間

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

Enum goal_status {
  not_started  [note: '尚未開始']
  in_progress  [note: '進行中']
  completed    [note: '已完成（終態，不可再更改）']
  abandoned    [note: '放棄（可改回 in_progress）']

  Note: '狀態轉換：not_started→in_progress；in_progress→completed|abandoned；abandoned→in_progress；completed 為終態'
}

Enum mood_type {
  depressed  [note: '憂鬱']
  sad        [note: '難過']
  unhappy    [note: '不開心']
  neutral    [note: '普通']
  good       [note: '不錯']
  happy      [note: '開心']
}

Enum pet_species {
  capybara  [note: '水豚君']
  dog       [note: '狗']
  cat       [note: '貓']
  snake     [note: '蛇']
  rabbit    [note: '兔子']
  hamster   [note: '倉鼠']
  panda     [note: '熊貓']
  penguin   [note: '企鵝']
  fox       [note: '狐狸']
  dragon    [note: '龍']
}

// ─────────────────────────────────────────
// Tables
// ─────────────────────────────────────────

Table users {
  id           integer    [pk, increment]
  google_id    varchar    [unique, not null, note: 'Google OAuth 識別碼']
  display_name varchar    [not null, note: '預設來自 Google，使用者可自訂']
  avatar_url   varchar    [note: '大頭照 URL，預設來自 Google，使用者可自訂上傳']
  created_by   integer    [not null, note: '建立者（首次登入時為自身 id）']
  created_at   timestamp  [not null, default: `now()`]
  updated_by   integer
  updated_at   timestamp

  Note: '登入使用者帳號，以 Google OAuth 身份識別'
}

Table learning_goals {
  id          integer      [pk, increment]
  user_id     integer      [not null, ref: > users.id]
  title       varchar      [not null, note: '目標標題，必填']
  description text         [note: '目標描述，選填']
  start_date  date         [note: '開始日期，選填']
  end_date    date         [note: '截止日期，選填']
  status      goal_status  [not null, default: 'not_started']
  created_by  integer      [not null, ref: > users.id]
  created_at  timestamp    [not null, default: `now()`]
  updated_by  integer      [ref: > users.id]
  updated_at  timestamp

  indexes {
    user_id [name: 'idx_learning_goals_user_id']
  }

  Note: '學習目標。status 初始為 not_started；completed 為終態不可更改'
}

Table learning_records {
  id          integer    [pk, increment]
  goal_id     integer    [not null, ref: > learning_goals.id]
  user_id     integer    [not null, ref: > users.id]
  title       varchar    [not null, note: '紀錄標題，必填']
  content     text       [note: '文字內容，選填']
  image_path  varchar    [note: '圖片儲存路徑（本地上傳後由 storage 產出），選填']
  entry_date  date       [not null, note: '紀錄所屬日期']
  created_by  integer    [not null, ref: > users.id]
  created_at  timestamp  [not null, default: `now()`]
  updated_by  integer    [ref: > users.id]
  updated_at  timestamp

  indexes {
    user_id    [name: 'idx_learning_records_user_id']
    goal_id    [name: 'idx_learning_records_goal_id']
    entry_date [name: 'idx_learning_records_entry_date']
  }

  Note: '學習紀錄，隸屬於一個學習目標。title 必填，content 與 image_path 皆選填'
}

Table mood_entries {
  id          integer    [pk, increment]
  user_id     integer    [not null, ref: > users.id]
  mood_type   mood_type  [not null]
  note        text       [note: '選填文字描述，提供更多心情細節']
  entry_date  date       [not null, note: '心情所屬日期']
  created_by  integer    [not null, ref: > users.id]
  created_at  timestamp  [not null, default: `now()`]
  updated_by  integer    [ref: > users.id]
  updated_at  timestamp

  indexes {
    user_id    [name: 'idx_mood_entries_user_id']
    entry_date [name: 'idx_mood_entries_entry_date']
  }

  Note: '心情記錄。mood_type 必填（6 種）；note 選填；自訂標籤見 mood_tags + mood_entry_tags（M:N）'
}

Table mood_tags {
  id         integer    [pk, increment]
  user_id    integer    [not null, ref: > users.id, note: '標籤屬於特定使用者']
  tag_name   varchar    [not null]
  created_by integer    [not null, ref: > users.id]
  created_at timestamp  [not null, default: `now()`]
  updated_by integer    [ref: > users.id]
  updated_at timestamp

  indexes {
    user_id [name: 'idx_mood_tags_user_id']
    (user_id, tag_name) [unique, name: 'uq_mood_tags_user_tag']
  }

  Note: '使用者自訂心情標籤定義。與 mood_entries 為 M:N（透過 mood_entry_tags）'
}

Table mood_entry_tags {
  mood_entry_id integer  [not null, ref: > mood_entries.id]
  tag_id        integer  [not null, ref: > mood_tags.id]

  indexes {
    (mood_entry_id, tag_id) [pk]
    tag_id [name: 'idx_mood_entry_tags_tag_id']
  }

  Note: 'mood_entries ↔ mood_tags 多對多 junction table'
}

Table gratitude_entries {
  id          integer    [pk, increment]
  user_id     integer    [not null, ref: > users.id]
  content     text       [not null, note: '感謝內容，必填']
  entry_date  date       [not null, note: '感謝日期，記錄當天日期']
  created_by  integer    [not null, ref: > users.id]
  created_at  timestamp  [not null, default: `now()`]
  updated_by  integer    [ref: > users.id]
  updated_at  timestamp

  indexes {
    user_id    [name: 'idx_gratitude_entries_user_id']
    entry_date [name: 'idx_gratitude_entries_entry_date']
  }

  Note: '感謝日記條目。每日可有多筆。可編輯與刪除'
}

Table pets {
  id          integer     [pk, increment]
  user_id     integer     [unique, not null, ref: - users.id]
  pet_name    varchar     [not null, note: '使用者自訂寵物名稱']
  species     pet_species [not null]
  happiness   integer     [not null, default: 100, note: '快樂值 0-100']
  fullness    integer     [not null, default: 100, note: '飽食度 0-100']
  level       integer     [not null, default: 1,   note: '等級，從 1 開始']
  created_by  integer     [not null, ref: > users.id]
  created_at  timestamp   [not null, default: `now()`]
  updated_by  integer     [ref: > users.id]
  updated_at  timestamp

  Note: '電子寵物。每人一隻。初始值：happiness=100, fullness=100, level=1'
}

// ─────────────────────────────────────────
// 行為連動規則（Phase 05 實作參考）
// ─────────────────────────────────────────
// | 行為             | happiness | fullness | level_exp |
// | 新增學習紀錄      | +10       | —        | +15       |
// | 新增感謝條目      | +8        | —        | +10       |
// | 記錄心情         | +3        | —        | +3        |
// | 餵食寵物         | —         | +20      | —         |
